{
  "name": "claude-infra-plugins",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "./scripts/style.sh lint --python --docs --shell",
    "lint:modified": "./scripts/style.sh lint --modified --python --docs --shell",
    "lint:staged": "./scripts/style.sh lint --staged --python --docs --shell",
    "lint:unstaged": "./scripts/style.sh lint --unstaged --python --docs --shell",
    "lint:fix": "./scripts/style.sh lint --fix --python --docs --shell",
    "lint:fix:modified": "./scripts/style.sh lint --fix --modified --python --docs --shell",
    "format": "./scripts/style.sh format --python --docs",
    "format:modified": "./scripts/style.sh format --modified --python --docs",
    "format:staged": "./scripts/style.sh format --staged --python --docs",
    "format:unstaged": "./scripts/style.sh format --unstaged --python --docs"
  },
  "devDependencies": {
    "markdownlint-cli": "^0.42.0",
    "prettier": "^3.3.3"
  }
