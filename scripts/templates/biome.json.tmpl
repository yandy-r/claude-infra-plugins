{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/node_modules",
      "!**/target",
      "!**/build",
      "!**/dist",
      "!**/out",
      "!**/coverage",
      "!**/vendor",
      "!**/.venv",
      "!**/venv",
      "!**/env",
      "!**/__pycache__",
      "!**/.mypy_cache",
      "!**/.pytest_cache",
      "!**/.ruff_cache",
      "!**/.next",
      "!**/.nuxt",
      "!**/.cache",
      "!**/.terraform",
      "!**/.cursor-plugin",
      "!**/.codex-plugin",
      "!**/.opencode-plugin"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always",
      "bracketSpacing": true
    }
  },
  "json": {
    "formatter": {
      "enabled": true,
      "indentWidth": 2
    }
  }
}
